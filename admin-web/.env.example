# ============================================================
# E-PKL Admin Web — Environment Variables
# ============================================================
# Salin file ini sebagai `.env` lalu isi nilai sebenarnya.
# JANGAN commit file .env ke repository!
#
#   cp .env.example .env
#
# ============================================================

# ── Supabase (WAJIB) ──────────────────────────────────────
# Dapatkan dari: Supabase Dashboard → Settings → API

VITE_SUPABASE_URL=https://<project-id>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-public-key>

# ── Google Maps (WAJIB) ───────────────────────────────────
# Dapatkan dari: Google Cloud Console → Credentials
# Enable API: Maps JavaScript API, Places API

VITE_GOOGLE_MAPS_API_KEY=<google-maps-api-key>

# ── Supabase Service Role (OPSIONAL) ──────────────────────
# Hanya untuk menjalankan admin scripts di folder scripts/
# (import-students.ts, update-profiles.ts)
# JANGAN gunakan di sisi client/frontend!

SERVICE_ROLE_KEY=<service-role-key>
